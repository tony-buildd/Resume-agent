{
  "name": "resume-agent",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web exec tsc --noEmit",
    "dev:api": "python3 -m uvicorn app.main:app --app-dir apps/api --reload",
    "check:api": "python3 -c \"from app.main import app; print(app.title)\""
  },
  "devDependencies": {
    "flag": "5.0.1",
    "prettier": "3.8.1"
  }
}
