{
  "name": "resume-agent",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web exec tsc --noEmit",
    "dev:api": "python3 -m uvicorn app.main:app --app-dir apps/api --reload --reload-dir apps/api",
    "check:api": ".venv/bin/python3 -c \"import sys; sys.path.insert(0, 'apps/api'); from app.main import app; print(app.title)\""
  },
  "devDependencies": {
    "flag": "5.0.1",
    "prettier": "3.8.1"
  }
}
